# ================================
# HEALTHCARE ETL PLATFORM
# Environment Variables Template
# ================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena TODOS los valores reales
# 3. NUNCA subas .env a GitHub (está en .gitignore)
# 4. En Render, agrega estas variables en el dashboard de cada servicio
# ================================


# ── DJANGO ────────────────────────────────────────────────────────────────────
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-in-production

# Siempre False en producción
DEBUG=False

# Módulo de configuración de Django
DJANGO_SETTINGS_MODULE=config.settings

# Dominios permitidos (sin https://)
# Producción: healthcare-backend.onrender.com,.onrender.com
# Local: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com


# ── BASE DE DATOS - SUPABASE ──────────────────────────────────────────────────
# Django usa DATABASE_URL (estándar dj-database-url)
# Encuéntrala en: Supabase Dashboard → Settings → Database → Connection string (URI)
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:Niidea123@db.ajuiklwcywulfrsyurlf.supabase.co:5432/postgres
# SUPABASE_URL: mismo valor que DATABASE_URL (para compatibilidad con código legacy)
SUPABASE_URL=postgresql://postgres:Niidea123@db.ajuiklwcywulfrsyurlf.supabase.co:5432/postgres


# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs del frontend separadas por coma (con https:// completo)
# Local:      http://localhost:3000,http://localhost:5173
# Producción: https://healthcare-frontend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://healthcare-frontend.onrender.com
CORS_ALLOW_CREDENTIALS=True


# ── JWT ───────────────────────────────────────────────────────────────────────
# Tiempo de vida en minutos
ACCESS_TOKEN_LIFETIME=30
REFRESH_TOKEN_LIFETIME=1440


# ── REDIS + CELERY ────────────────────────────────────────────────────────────
# Local:      redis://localhost:6379/0
# Producción: Render lo inyecta automáticamente desde el servicio Redis
REDIS_URL=redis://localhost:6379/0

# Celery usa bases de datos separadas de Redis para evitar colisiones
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=America/Bogota


# ── FRONTEND - VITE ───────────────────────────────────────────────────────────
# URL del backend que usará React para hacer peticiones
# Local:      http://localhost:8000/api
# Producción: https://healthcare-backend.onrender.com/api
VITE_API_URL=http://localhost:8000/api
NODE_ENV=development


# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


# ── EMAIL (Opcional) ──────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password


# ── AWS S3 (Opcional, para almacenamiento de archivos) ────────────────────────
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1


# ── NOTA: Variables que Render inyecta automáticamente ────────────────────────
# No las configures tú, Render las pone solo:
# PORT              → Puerto del servicio
# RENDER            → "true" cuando corre en Render
# RENDER_SERVICE_NAME → Nombre del servicio
