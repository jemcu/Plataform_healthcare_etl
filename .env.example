# ================================
# HEALTHCARE ETL PLATFORM
# Environment Variables Template
# ================================

# IMPORTANT: This is a template file.
# Create a .env file from this template and fill in your actual values.
# NEVER commit .env to git (it's in .gitignore)

# ── DJANGO CONFIGURATION ──────────────────────────────────────────────────────
# DEBUG: Set to False in production
DEBUG=False

# SECRET_KEY: Generate a strong random key in production
# Python: from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())
SECRET_KEY=your-secret-key-here-change-in-production

# ALLOWED_HOSTS: Domains that can access this backend
# For Render: healthcare-backend.onrender.com,.onrender.com
# For local dev: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ── DATABASE CONFIGURATION ────────────────────────────────────────────────────
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database_name
#
# SUPABASE EXAMPLE:
# SUPABASE_URL=postgresql://postgres:MyPassword@db.ajuiklwcywulfrsyurlf.supabase.co:5432/postgres
#
# LOCAL POSTGRES EXAMPLE:
# SUPABASE_URL=postgresql://healthcare_user:healthcare_pass@localhost:5432/healthcare_db
#
# Render will auto-fill this if you use a PostgreSQL service

SUPABASE_URL=postgresql://user:password@db.example.com:5432/healthcare_db

# ── CORS & ALLOWED ORIGINS ────────────────────────────────────────────────────
# Frontend URLs that can make requests to this backend
# Local dev: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://app.yourdomain.com
# Render: https://healthcare-frontend.onrender.com

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://healthcare-frontend.onrender.com

# ── JWT TOKEN CONFIGURATION ───────────────────────────────────────────────────
# Access token lifetime in minutes (30 = 30 minutes)
ACCESS_TOKEN_LIFETIME=30

# Refresh token lifetime in minutes (1440 = 24 hours)
REFRESH_TOKEN_LIFETIME=1440

# ── REDIS CONFIGURATION (for Celery & Caching) ────────────────────────────────
# Local: redis://localhost:6379/0
# Render: Will be auto-filled from Redis service
# Remote: redis://:password@host:port/0

REDIS_URL=redis://localhost:6379/0

# ── CELERY CONFIGURATION ──────────────────────────────────────────────────────
# Broker URL (where tasks are queued)
# Usually Redis database 1
CELERY_BROKER_URL=redis://localhost:6379/1

# Result backend (where task results are stored)
# Usually Redis database 2
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Celery serialization settings
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=America/Bogota

# ── FRONTEND API URL ──────────────────────────────────────────────────────────
# Used by React frontend to know where backend is located
# Local dev: http://localhost:8000/api
# Production/Render: https://healthcare-backend.onrender.com/api

VITE_API_URL=http://localhost:8000/api

# ── LOGGING CONFIGURATION ─────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── EMAIL CONFIGURATION (Optional) ────────────────────────────────────────────
# Uncomment and fill in to enable email functionality
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ── AWS S3 CONFIGURATION (Optional for file storage) ──────────────────────────
# Uncomment and fill in to use S3 for storing files
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

