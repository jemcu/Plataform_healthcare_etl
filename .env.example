# ================================
# HEALTHCARE ETL PLATFORM
# Environment Variables Template
# ================================

# ── DJANGO CONFIGURATION ──────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,.onrender.com

# ── DATABASE CONFIGURATION ────────────────────────────────────────────────────
# PostgreSQL via Supabase (production) or local PostgreSQL
# Format: postgresql://user:password@host:port/database_name
SUPABASE_URL=postgresql://user:password@db.example.com:5432/healthcare_db
DATABASE_URL=${SUPABASE_URL}

# ── CORS & ALLOWED ORIGINS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com,https://app.yourdomain.com

# ── JWT TOKEN CONFIGURATION ───────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME=30
REFRESH_TOKEN_LIFETIME=1440

# ── REDIS CONFIGURATION (for Celery & Caching) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CELERY CONFIGURATION ──────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=America/Bogota

# ── FRONTEND API URL ──────────────────────────────────────────────────────────
# Used by frontend .env
VITE_API_URL=http://localhost:8000/api

# ── LOGGING CONFIGURATION ─────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── EMAIL CONFIGURATION (Optional) ────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ── AWS S3 CONFIGURATION (Optional for file storage) ──────────────────────────
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
